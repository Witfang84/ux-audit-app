{
  "name": "ux-audit-plugin",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build:code": "bun build src/code.ts --outfile dist/code.js --target browser",
    "build:ui": "vite build",
    "build": "bun run build:code && bun run build:ui",
    "dev:code": "bun build src/code.ts --outfile dist/code.js --target browser --watch",
    "dev:ui": "vite build --watch",
    "dev": "concurrently \"bun run dev:code\" \"bun run dev:ui\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.96.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "webpack": "^5.96.0",
    "webpack-cli": "^5.1.4"
  }
}
